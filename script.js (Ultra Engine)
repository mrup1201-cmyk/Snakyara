const tg = window.Telegram?.WebApp;
if (tg) {
    tg.expand();
    tg.setHeaderColor("#0f172a");
}

const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

const grid = 20;

let snake, dir, food, bonus;
let score = 0;
let best = localStorage.getItem("best") || 0;

document.getElementById("best").innerText = best;

let speed = 8;
let lastTime = 0;

function reset(){
    snake = [{x:10,y:10}];
    dir = {x:1,y:0};
    score = 0;
    spawnFood();
}

function spawnFood(){
    food = {
        x: Math.floor(Math.random()*20),
        y: Math.floor(Math.random()*20)
    };
}

function spawnBonus(){
    if (Math.random() > 0.92) {
        bonus = {
            x: Math.floor(Math.random()*20),
            y: Math.floor(Math.random()*20),
            life: 80
        };
    }
}

function game(time){

    requestAnimationFrame(game);

    if (time - lastTime < 1000/speed) return;
    lastTime = time;

    const head = {
        x: snake[0].x + dir.x,
        y: snake[0].y + dir.y
    };

    // walls
    if (head.x < 0 || head.y < 0 ||
        head.x >= 20 || head.y >= 20) {
        reset();
    }

    snake.unshift(head);

    if (head.x === food.x && head.y === food.y){
        score++;
        spawnFood();
        spawnBonus();
        speed += 0.1;
    } else {
        snake.pop();
    }

    if (bonus && head.x === bonus.x && head.y === bonus.y){
        score += 5;
        bonus = null;

        if (tg?.HapticFeedback) {
            tg.HapticFeedback.notificationOccurred("success");
        }
    }

    if (score > best){
        best = score;
        localStorage.setItem("best", best);
        document.getElementById("best").innerText = best;
    }

    draw();
}

function draw(){

    ctx.fillStyle = "#0b1220";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    // food
    ctx.shadowBlur = 20;
    ctx.shadowColor = "red";
    ctx.fillStyle = "red";
    ctx.fillRect(food.x*grid, food.y*grid, grid-2, grid-2);

    // bonus
    if (bonus){
        ctx.shadowColor = "gold";
        ctx.fillStyle = "gold";
        ctx.fillRect(bonus.x*grid, bonus.y*grid, grid-2, grid-2);
    }

    // snake glow
    ctx.shadowBlur = 15;
    ctx.shadowColor = "#00ff88";

    snake.forEach((s,i)=>{
        ctx.fillStyle = i===0 ? "#00ff88" : "#00aa55";
        ctx.fillRect(s.x*grid, s.y*grid, grid-2, grid-2);
    });
}

/* SWIPE CONTROL (ultra fast) */
let sx, sy;

document.addEventListener("touchstart", e=>{
    sx = e.touches[0].clientX;
    sy = e.touches[0].clientY;
}, {passive:true});

document.addEventListener("touchend", e=>{
    const dx = e.changedTouches[0].clientX - sx;
    const dy = e.changedTouches[0].clientY - sy;

    if (Math.abs(dx) > Math.abs(dy)){
        if (dx > 0 && dir.x===0) dir={x:1,y:0};
        else if (dx < 0 && dir.x===0) dir={x:-1,y:0};
    } else {
        if (dy > 0 && dir.y===0) dir={x:0,y:1};
        else if (dy < 0 && dir.y===0) dir={x:0,y:-1};
    }
}, {passive:true});

function startGame(){
    document.getElementById("menu").style.display = "none";
    reset();
    requestAnimationFrame(game);
}
